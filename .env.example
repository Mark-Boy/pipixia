# pipixia
DATABASE_URL=postgresql+asyncpg://pipixia:pipixia_secret@postgres:5432/pipixia
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin-secret
MINIO_BUCKET=pipixia-images

# LLM
DASHSCOPE_API_KEY=your-dashscope-api-key-here
LLM_MODEL=qwen-plus

# Shopee
SHOPEE_MARKET_ID=146
SHOPEE_SIGNATURE_ENABLED=false

# JWT
SECRET_KEY=change-this-to-a-real-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
